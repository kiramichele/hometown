# Copy this file to .env and fill in real values
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/hometown
JWT_SECRET=change-me-to-a-long-random-string
CLIENT_ORIGIN=http://localhost:5173
# Marketplace image uploads (Phase 4). Get this from your Cloudinary dashboard.
# Without it, image upload returns a 503 and the rest of the app still works.
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
